{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and account settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "username": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "isPrivate": { "type": "boolean" },
        "followerCount": { "type": "number" },
        "followingCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "online": { "type": "boolean" },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "username"]
    },
    "Post": {
      "title": "Post",
      "description": "Social media post (Image, Video, or Reel)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "type": { "type": "string", "enum": ["post", "reel"] },
        "mediaUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "caption": { "type": "string" },
        "hashtags": { "type": "array", "items": { "type": "string" } },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "viewCount": { "type": "number" },
        "isPrivate": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "type", "mediaUrl"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Comment on a post/reel",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "text"]
    },
    "Follow": {
      "title": "Follow",
      "description": "Follow relationship or request",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followingId", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "video"] },
        "seen": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "type"]
    },
    "Chat": {
      "title": "Chat",
      "description": "One-to-one or Group chat session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["direct", "group"] },
        "participants": { "type": "array", "items": { "type": "string" } },
        "name": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "participants"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "recipientId": { "type": "string" },
        "senderId": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "comment", "follow", "message"] },
        "targetId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["recipientId", "type"]
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "Users collection" },
    "posts": { "schema": "Post", "description": "Posts and Reels collection" },
    "posts/{postId}/comments": { "schema": "Comment", "description": "Comments subcollection" },
    "follows": { "schema": "Follow", "description": "Root collection for following relationships" },
    "chats": { "schema": "Chat", "description": "Chat sessions" },
    "chats/{chatId}/messages": { "schema": "Message", "description": "Messages in a chat" },
    "notifications": { "schema": "Notification", "description": "User notifications" }
  }
}
